#!/bin/bash
# aictl — CLI pour gerer les serveurs IA locaux
# Source de verite: ~/ai-servers/servers.yaml
#
# Usage: aictl <command> [name|all]
# Commands: list, status, start, stop, restart, logs, install, uninstall, health

# Only fail on unset vars, not on non-zero exits (lsof, grep, etc. return 1 on no match)
set -u

# ── Config ──────────────────────────────────────────────────────────────────
# Resolve symlinks to find the real directory (not the symlink location)
_self="$0"
[[ -L "$_self" ]] && _self="$(readlink "$_self")"
AICTL_DIR="$(cd "$(dirname "$_self")" && pwd)"
YAML_FILE="$AICTL_DIR/servers.yaml"
LOGS_DIR="$AICTL_DIR/logs"
PLIST_PREFIX="com.ai-servers"
LAUNCH_AGENTS_DIR="$HOME/Library/LaunchAgents"

# ── Colors ──────────────────────────────────────────────────────────────────
if [[ -t 1 ]]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[0;33m'
    BLUE='\033[0;34m'
    CYAN='\033[0;36m'
    BOLD='\033[1m'
    DIM='\033[2m'
    NC='\033[0m'
else
    RED='' GREEN='' YELLOW='' BLUE='' CYAN='' BOLD='' DIM='' NC=''
fi

# ── YAML parser ─────────────────────────────────────────────────────────────

get_server_ids() {
    awk '
        /^servers:/ { in_servers=1; next }
        in_servers && /^  [a-zA-Z]/ && !/^    / {
            gsub(/:.*/, ""); gsub(/^  /, ""); print
        }
    ' "$YAML_FILE"
}

get_server_field() {
    local id="$1" field="$2"
    awk -v id="$id" -v field="$field" '
        /^  [a-zA-Z]/ && !/^    / {
            gsub(/:.*/, ""); gsub(/^  /, "")
            current = $0
        }
        current == id && $0 ~ "^    " field ":" {
            val = $0
            sub(/^[^:]+: */, "", val)
            gsub(/^"/, "", val); gsub(/"$/, "", val)
            print val
            exit
        }
    ' "$YAML_FILE"
}

validate_server_id() {
    local id="$1"
    if ! get_server_ids | grep -qx "$id"; then
        echo -e "${RED}Error: unknown server '$id'${NC}"
        echo "Available servers:"
        get_server_ids | sed 's/^/  /'
        exit 1
    fi
}

is_managed_externally() {
    local id="$1"
    local managed
    managed=$(get_server_field "$id" "managed_by")
    [[ -n "$managed" ]]
}

# ── Plist generation ────────────────────────────────────────────────────────

generate_plist() {
    local id="$1"
    local name launcher autostart keepalive log_stdout log_stderr throttle working_dir

    name=$(get_server_field "$id" "name")
    launcher=$(get_server_field "$id" "launcher")
    autostart=$(get_server_field "$id" "autostart")
    keepalive=$(get_server_field "$id" "keepalive")
    log_stdout=$(get_server_field "$id" "log_stdout")
    log_stderr=$(get_server_field "$id" "log_stderr")
    throttle=$(get_server_field "$id" "throttle")
    working_dir=$(get_server_field "$id" "working_dir")

    [[ -z "$throttle" ]] && throttle=30
    local run_at_load="false"
    [[ "$autostart" == "true" ]] && run_at_load="true"
    local keep_alive="false"
    [[ "$keepalive" == "true" ]] && keep_alive="true"

    local launcher_abs="$AICTL_DIR/$launcher"
    local log_stdout_abs="$AICTL_DIR/$log_stdout"
    local log_stderr_abs="$AICTL_DIR/$log_stderr"

    cat <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Generated by aictl — do not edit manually -->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>${PLIST_PREFIX}.${id}</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>${launcher_abs}</string>
    </array>
    <key>RunAtLoad</key>
    <${run_at_load}/>
    <key>KeepAlive</key>
    <${keep_alive}/>
    <key>StandardOutPath</key>
    <string>${log_stdout_abs}</string>
    <key>StandardErrorPath</key>
    <string>${log_stderr_abs}</string>
    <key>ThrottleInterval</key>
    <integer>${throttle}</integer>
PLIST
    if [[ -n "$working_dir" ]]; then
        cat <<PLIST
    <key>WorkingDirectory</key>
    <string>${working_dir}</string>
PLIST
    fi
    cat <<PLIST
</dict>
</plist>
PLIST
}

# ── Commands ────────────────────────────────────────────────────────────────

cmd_list() {
    printf "${BOLD}%-22s %-30s %-12s %-7s %-6s${NC}\n" "ID" "NAME" "CATEGORY" "PORT" "DISK"
    echo "────────────────────── ────────────────────────────── ──────────── ─────── ──────"

    local id
    for id in $(get_server_ids); do
        local name category port requires_disk managed_by disk
        name=$(get_server_field "$id" "name")
        category=$(get_server_field "$id" "category")
        port=$(get_server_field "$id" "port")
        requires_disk=$(get_server_field "$id" "requires_disk")
        managed_by=$(get_server_field "$id" "managed_by")

        [[ "$port" == "null" || -z "$port" ]] && port="--"
        [[ "$requires_disk" == "true" ]] && disk="PRO-G40" || disk="--"
        [[ -n "$managed_by" ]] && name="$name ($managed_by)"

        printf "%-22s %-30s %-12s %-7s %-6s\n" "$id" "$name" "$category" "$port" "$disk"
    done
}

cmd_status() {
    printf "${BOLD}%-22s %7s  %-6s  %8s  %8s  %s${NC}\n" "ID" "PORT" "STATUS" "PID" "RSS MB" "UPTIME"
    echo "────────────────────── ───────  ──────  ────────  ────────  ──────────"

    local id
    for id in $(get_server_ids); do
        local port managed_by status_text status_color pid rss uptime_str
        port=$(get_server_field "$id" "port")
        managed_by=$(get_server_field "$id" "managed_by")

        pid="--"
        rss="--"
        uptime_str="--"
        status_text="DOWN"
        status_color="$RED"

        if [[ -n "$managed_by" ]]; then
            if [[ "$managed_by" == "brew" ]]; then
                local brew_info
                brew_info=$(brew services info "$id" 2>/dev/null || true)
                if echo "$brew_info" | grep -q "Running: true"; then
                    local brew_pid
                    brew_pid=$(echo "$brew_info" | grep "PID:" | awk '{print $2}')
                    status_text="UP"
                    status_color="$GREEN"
                    pid="${brew_pid:---}"
                    if [[ "$pid" != "--" ]]; then
                        rss=$(ps -o rss= -p "$pid" 2>/dev/null | awk '{printf "%.0f", $1/1024}' || true)
                        [[ -z "$rss" ]] && rss="--"
                    fi
                fi
            else
                status_text="EXT"
                status_color="$DIM"
            fi
        elif [[ "$port" == "null" || -z "$port" ]]; then
            # App without port
            local app_name process_match launcher launcher_abs
            app_name=$(get_server_field "$id" "name")
            process_match=$(get_server_field "$id" "process_match")
            launcher=$(get_server_field "$id" "launcher")
            launcher_abs="$AICTL_DIR/$launcher"
            [[ -z "$process_match" ]] && process_match="$launcher_abs"
            local app_pid
            app_pid=$(pgrep -f "$process_match" 2>/dev/null | head -1 || true)
            if [[ -n "$app_pid" ]]; then
                status_text="UP"
                status_color="$GREEN"
                pid="$app_pid"
                rss=$(ps -o rss= -p "$pid" 2>/dev/null | awk '{printf "%.0f", $1/1024}' || true)
                [[ -z "$rss" ]] && rss="--"
            fi
        else
            # Regular server with port
            local port_pid
            port_pid=$(lsof -ti "TCP:${port}" -sTCP:LISTEN 2>/dev/null | head -1 || true)
            if [[ -n "$port_pid" ]]; then
                status_text="UP"
                status_color="$GREEN"
                pid="$port_pid"
                rss=$(ps -o rss= -p "$pid" 2>/dev/null | awk '{printf "%.0f", $1/1024}' || true)
                [[ -z "$rss" ]] && rss="--"
                local etime
                etime=$(ps -o etime= -p "$pid" 2>/dev/null | tr -d ' ' || true)
                [[ -n "$etime" ]] && uptime_str="$etime"
            fi
        fi

        local display_port="$port"
        [[ "$port" == "null" || -z "$port" ]] && display_port="--"

        printf "%-22s %7s  ${status_color}%-6s${NC}  %8s  %8s  %s\n" \
            "$id" "$display_port" "$status_text" "$pid" "$rss" "$uptime_str"
    done
}

cmd_start() {
    local target="$1"

    if [[ "$target" == "all" ]]; then
        local id
        for id in $(get_server_ids); do
            cmd_start "$id"
        done
        return
    fi

    validate_server_id "$target"

    if is_managed_externally "$target"; then
        local managed_by
        managed_by=$(get_server_field "$target" "managed_by")
        echo -e "${YELLOW}$target is managed by $managed_by. Use: $managed_by services start $target${NC}"
        return
    fi

    local plist_file="${LAUNCH_AGENTS_DIR}/${PLIST_PREFIX}.${target}.plist"
    if [[ ! -f "$plist_file" ]]; then
        echo -e "${RED}Plist not found for $target. Run 'aictl install' first.${NC}"
        return 1
    fi

    echo -n "Starting $target... "
    launchctl load "$plist_file" 2>/dev/null || true

    local port
    port=$(get_server_field "$target" "port")
    if [[ -n "$port" && "$port" != "null" ]]; then
        local i
        for i in {1..10}; do
            if lsof -ti "TCP:${port}" -sTCP:LISTEN &>/dev/null; then
                echo -e "${GREEN}OK${NC} (port $port)"
                return
            fi
            sleep 1
        done
        echo -e "${YELLOW}started (port $port not yet listening)${NC}"
    else
        echo -e "${GREEN}OK${NC}"
    fi
}

cmd_stop() {
    local target="$1"

    if [[ "$target" == "all" ]]; then
        local id
        for id in $(get_server_ids); do
            cmd_stop "$id"
        done
        return
    fi

    validate_server_id "$target"

    if is_managed_externally "$target"; then
        local managed_by
        managed_by=$(get_server_field "$target" "managed_by")
        echo -e "${YELLOW}$target is managed by $managed_by. Use: $managed_by services stop $target${NC}"
        return
    fi

    local plist_file="${LAUNCH_AGENTS_DIR}/${PLIST_PREFIX}.${target}.plist"
    if [[ ! -f "$plist_file" ]]; then
        echo -e "${DIM}$target: no plist found${NC}"
        return
    fi

    echo -n "Stopping $target... "
    launchctl unload "$plist_file" 2>/dev/null || true
    echo -e "${GREEN}OK${NC}"
}

cmd_restart() {
    local target="$1"

    if [[ "$target" == "all" ]]; then
        local id
        for id in $(get_server_ids); do
            cmd_restart "$id"
        done
        return
    fi

    validate_server_id "$target"
    cmd_stop "$target"
    sleep 1
    cmd_start "$target"
}

cmd_logs() {
    local target="$1"
    validate_server_id "$target"

    local log_stdout log_stderr
    log_stdout=$(get_server_field "$target" "log_stdout")
    log_stderr=$(get_server_field "$target" "log_stderr")

    local stdout_abs="$AICTL_DIR/$log_stdout"
    local stderr_abs="$AICTL_DIR/$log_stderr"

    local files=()
    [[ -f "$stdout_abs" ]] && files+=("$stdout_abs")
    [[ -f "$stderr_abs" && "$stderr_abs" != "$stdout_abs" ]] && files+=("$stderr_abs")

    if [[ ${#files[@]} -eq 0 ]]; then
        echo -e "${YELLOW}No log files found for $target${NC}"
        echo "  Expected: $stdout_abs"
        return
    fi

    echo -e "${CYAN}Tailing logs for $target...${NC} (Ctrl+C to stop)"
    tail -f "${files[@]}"
}

cmd_install() {
    echo -e "${BOLD}Installing LaunchAgents from servers.yaml...${NC}"
    mkdir -p "$LAUNCH_AGENTS_DIR" "$LOGS_DIR"

    local count=0
    local id
    for id in $(get_server_ids); do
        if is_managed_externally "$id"; then
            echo -e "  ${DIM}skip $id (managed externally)${NC}"
            continue
        fi

        local plist_file="${LAUNCH_AGENTS_DIR}/${PLIST_PREFIX}.${id}.plist"

        # Unload if already loaded
        launchctl list "${PLIST_PREFIX}.${id}" &>/dev/null && \
            launchctl unload "$plist_file" 2>/dev/null || true

        # Generate and write plist
        generate_plist "$id" > "$plist_file"

        # Load
        launchctl load "$plist_file"
        echo -e "  ${GREEN}+${NC} ${id}"
        count=$((count + 1))
    done

    echo ""
    echo -e "${GREEN}Installed $count LaunchAgents.${NC}"
    echo "Plist prefix: ${PLIST_PREFIX}.*"
}

cmd_uninstall() {
    local target="${1:-}"

    if [[ -z "$target" ]]; then
        echo -e "${BOLD}Uninstalling ALL ai-servers LaunchAgents...${NC}"
        local id
        for id in $(get_server_ids); do
            is_managed_externally "$id" && continue
            cmd_uninstall "$id"
        done
        return
    fi

    validate_server_id "$target"

    if is_managed_externally "$target"; then
        echo -e "${YELLOW}$target is managed externally, skip${NC}"
        return
    fi

    local plist_file="${LAUNCH_AGENTS_DIR}/${PLIST_PREFIX}.${target}.plist"
    if [[ -f "$plist_file" ]]; then
        launchctl unload "$plist_file" 2>/dev/null || true
        rm "$plist_file"
        echo -e "  ${RED}-${NC} ${target}"
    else
        echo -e "  ${DIM}$target: no plist to remove${NC}"
    fi
}

cmd_health() {
    echo -e "${BOLD}Health checks...${NC}"
    echo ""

    local ok=0 fail=0 skip=0
    local id
    for id in $(get_server_ids); do
        local port host health_endpoint managed_by
        port=$(get_server_field "$id" "port")
        host=$(get_server_field "$id" "host")
        health_endpoint=$(get_server_field "$id" "health_endpoint")
        managed_by=$(get_server_field "$id" "managed_by")

        [[ -z "$host" ]] && host="127.0.0.1"
        [[ -z "$health_endpoint" ]] && health_endpoint="/health"

        if [[ "$port" == "null" || -z "$port" ]]; then
            echo -e "  ${DIM}SKIP $id (no port)${NC}"
            skip=$((skip + 1))
            continue
        fi

        local url="http://${host}:${port}${health_endpoint}"
        local http_code
        http_code=$(curl -s -o /dev/null -w "%{http_code}" --max-time 3 "$url" 2>/dev/null) || http_code="000"

        if [[ "$http_code" -ge 200 && "$http_code" -lt 400 ]]; then
            echo -e "  ${GREEN}OK${NC}   $id  ${DIM}${url} -> ${http_code}${NC}"
            ok=$((ok + 1))
        else
            echo -e "  ${RED}FAIL${NC} $id  ${DIM}${url} -> ${http_code}${NC}"
            fail=$((fail + 1))
        fi
    done

    echo ""
    echo -e "${GREEN}$ok OK${NC}  ${RED}$fail FAIL${NC}  ${DIM}$skip skipped${NC}"
}

# ── Usage ───────────────────────────────────────────────────────────────────

usage() {
    echo -e "${BOLD}aictl${NC} -- Gestion centralisee des serveurs IA locaux"
    echo ""
    echo -e "${BOLD}Usage:${NC}"
    echo "  aictl <command> [name|all]"
    echo ""
    echo -e "${BOLD}Commands:${NC}"
    echo "  list                    Liste des serveurs (nom, port, categorie)"
    echo "  status                  Status live (PID, port, RAM, uptime)"
    echo "  start <name|all>        Demarrer un serveur ou tous"
    echo "  stop <name|all>         Arreter un serveur ou tous"
    echo "  restart <name|all>      Stop + Start"
    echo "  logs <name>             tail -f les logs du serveur"
    echo "  install                 Generer et charger les LaunchAgents depuis servers.yaml"
    echo "  uninstall [name]        Decharger et supprimer les LaunchAgents"
    echo "  health                  Health check HTTP sur tous les ports"
    echo ""
    echo -e "${BOLD}Examples:${NC}"
    echo "  aictl status"
    echo "  aictl start medgemma-27b"
    echo "  aictl restart all"
    echo "  aictl logs embedding"
    echo "  aictl health"
    echo ""
    echo -e "${BOLD}Config:${NC} $YAML_FILE"
}

# ── Main ────────────────────────────────────────────────────────────────────

if [[ $# -lt 1 ]]; then
    usage
    exit 0
fi

command="$1"
shift

case "$command" in
    list)      cmd_list ;;
    status)    cmd_status ;;
    start)     [[ $# -lt 1 ]] && { echo "Usage: aictl start <name|all>"; exit 1; }; cmd_start "$1" ;;
    stop)      [[ $# -lt 1 ]] && { echo "Usage: aictl stop <name|all>"; exit 1; }; cmd_stop "$1" ;;
    restart)   [[ $# -lt 1 ]] && { echo "Usage: aictl restart <name|all>"; exit 1; }; cmd_restart "$1" ;;
    logs)      [[ $# -lt 1 ]] && { echo "Usage: aictl logs <name>"; exit 1; }; cmd_logs "$1" ;;
    install)   cmd_install ;;
    uninstall) cmd_uninstall "${1:-}" ;;
    health)    cmd_health ;;
    help|-h|--help) usage ;;
    *)
        echo -e "${RED}Unknown command: $command${NC}"
        usage
        exit 1
        ;;
esac
